# =========================================================================
# Variables de Entorno — Chihuahueños (Docker Compose)
# Copia este archivo como .env y ajusta los valores.
# =========================================================================

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=chihuahuenos_db

# ---- MinIO ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-minio-password

# ---- Backend (NestJS) ----
NODE_ENV=development
PORT=3000
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password
DB_DATABASE=chihuahuenos_db
JWT_SECRET=your-jwt-secret-change-in-prod
JWT_EXPIRATION=1d
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-password
MINIO_BUCKET_NAME=identificaciones
ADMIN_API_KEY=your-admin-api-key

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:3000
API_INTERNAL_URL=http://backend:3000
