# =========================================================================
# Gitignore para el monorrepo de Chihuahueños (Venta de Boletos)
# =========================================================================

# -------------------------------------------------------------------------
# Archivos del Sistema Operativo y Editores (Globales)
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -------------------------------------------------------------------------
# Logs de Diagnóstico (Globales)
# -------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------------------------------------------------------
# Archivos de Entorno y Credenciales (Seguridad)
# -------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env*.local
*.pem

# -------------------------------------------------------------------------
# Frontend (Next.js)
# -------------------------------------------------------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
frontend/.vercel/
frontend/*.tsbuildinfo

# -------------------------------------------------------------------------
# Backend (NestJS)
# -------------------------------------------------------------------------
backend/node_modules/
backend/dist/
backend/coverage/
backend/*.tsbuildinfo
